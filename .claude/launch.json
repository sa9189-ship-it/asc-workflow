{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "ASC Dev Server",
      "runtimeExecutable": "/bin/sh",
      "runtimeArgs": ["-c", "PATH=/usr/local/bin:$PATH node --watch server.js"],
