# Copy this file to .env and fill in your values.
# Never commit .env to version control.
#
# On Railway: add these under Settings → Variables (not as a file).

# ── Claude API (required) ────────────────────────────────────────────────────
# Your Anthropic API key — used for transcript extraction (Stage 2) and
# all AI generation (pitch deck, financial model). Get it at console.anthropic.com
ANTHROPIC_API_KEY=your_key_here

# ── Fireflies webhook (optional) ─────────────────────────────────────────────
# Secret token for verifying incoming Fireflies meeting webhooks (Stage 1).
# Leave blank if you're not using the Fireflies integration.
FIREFLIES_API_KEY=your_key_here

# ── Auth ─────────────────────────────────────────────────────────────────────
# Password for the consultant portal login page.
PORTAL_PASSWORD=ASCadvisors2026
# Secret used to sign session cookies — change this to a long random string.
COOKIE_SECRET=asc_workflow_secret_2026

# ── Server ────────────────────────────────────────────────────────────────────
# Railway sets PORT automatically — only needed for local development.
PORT=3000
